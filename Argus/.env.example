# ====================================
# Argus-Compound Configuration
# Copy to .env and customize values
# ====================================

# --- VLM (Visual Language Model) ---
VLM_API_BASE=http://localhost:8000/v1
VLM_API_KEY=EMPTY
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLM_MODE=api                    # "api" or "local"
VLM_TIMEOUT=60

# --- VLM Image Scaling (Token Savings) ---
VLM_IMAGE_MAX_DIM=1024          # Max long-edge pixels for VLM (saves ~87% tokens)
VLM_IMAGE_QUALITY=50            # JPEG quality for VLM (50=good balance)
DISPLAY_IMAGE_QUALITY=80        # JPEG quality for human display
VLM_MONITOR_INTERVAL_SEC=30     # Periodic VLM analysis interval (0=disabled)

# --- Ollama (Local Vision Model) ---
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b            # Set model name to auto-register Ollama as VLM provider

# --- Gemini Temporal Analysis ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TIMEOUT=120

# --- Security ---
ARGUS_API_KEY=                  # Leave empty to disable auth
RATE_LIMIT_QPS=10.0
ENABLE_PII_FILTER=true
ENABLE_GUARDRAILS=true

# --- Pipeline ---
KEYFRAME_THRESHOLD=0.05         # Pixel change ratio to trigger keyframe
KEYFRAME_MIN_INTERVAL_MS=500
KEYFRAME_MAX_INTERVAL_MS=30000
KEYFRAME_BUFFER_SIZE=1000

# --- Server ---
GO_SENSORY_PORT=8090
GO_SENSORY_FPS=10
GO_SENSORY_SHM=true             # Enable shared memory IPC
LOG_LEVEL=INFO
LOG_FORMAT=json                 # "json" or "text"

# --- Infrastructure (Docker) ---
POSTGRES_PASSWORD=argus_secret
REDIS_PASSWORD=
CHROMADB_PORT=8000
