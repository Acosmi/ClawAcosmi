<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Argus Compound</title>
    <organization>com.argus</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="false" rootVolumeOnly="true"/>

    <!-- Installation choices -->
    <choices-outline>
        <line choice="default">
            <line choice="com.argus.compound.pkg"/>
        </line>
    </choices-outline>

    <choice id="default"/>
    <choice id="com.argus.compound.pkg" visible="false">
        <pkg-ref id="com.argus.compound.pkg"/>
    </choice>

    <!-- Component package reference -->
    <pkg-ref id="com.argus.compound.pkg" version="1.0.0" onConclusion="none">Argus-component.pkg</pkg-ref>
</installer-gui-script>
